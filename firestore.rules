rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ==================== Helper Functions ====================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.get('admin', false) == true;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ==================== Users Collection ====================
    match /users/{userId} {
      // Users can read their own profile
      allow read: if isOwner(userId);
      
      // Users can create/update their own profile
      allow create, update: if isOwner(userId) &&
                              hasRequiredFields(['email', 'uid']);
      
      // Users can delete their own account
      allow delete: if isOwner(userId);
    }

    // ==================== Products Collection ====================
    // Anyone can read products
    // Only authenticated admins can create/update/delete products
    match /products/{productId} {
      // Read: Public access
      allow read: if true;

      // Create/Update: Admins only
      allow create, update: if isAdmin() &&
                              hasRequiredFields(['name', 'description', 'price']);

      // Delete: Admins only
      allow delete: if isAdmin();
    }

    // ==================== Carts Collection ====================
    // Users can only read and write their own cart
    match /carts/{userId} {
      // Read own cart
      allow read: if isOwner(userId);

      // Create/Update own cart
      allow create, update: if isOwner(userId) &&
                              hasRequiredFields(['userId', 'items']);

      // Delete own cart
      allow delete: if isOwner(userId);
    }

    // ==================== Orders Collection ====================
    // Users can only read and create their own orders
    match /orders/{orderId} {
      // Read own orders or admin can read all orders
      allow read: if isOwner(resource.data.userId) || isAdmin();

      // Create own orders
      allow create: if isAuthenticated() && 
                       isOwner(request.resource.data.userId) &&
                       hasRequiredFields(['userId', 'items', 'totalPrice']);

      // Update own orders (limited fields)
      allow update: if isOwner(resource.data.userId) &&
                       request.resource.data.userId == resource.data.userId;

      // Delete: Admins only
      allow delete: if isAdmin();
    }

    // ==================== Wishlist Collection ====================
    // Users can only read and write their own wishlist
    match /wishlists/{userId} {
      match /items/{itemId} {
        allow read, create, update, delete: if isOwner(userId);
      }
    }

    // ==================== Reviews Collection ====================
    // Anyone can read reviews
    // Users can create reviews for products they ordered
    match /reviews/{reviewId} {
      allow read: if true;
      
      allow create: if isAuthenticated() &&
                       hasRequiredFields(['userId', 'productId', 'rating', 'text']);
      
      // Users can update/delete their own reviews
      allow update, delete: if isOwner(resource.data.userId);
    }

    // ==================== Admin Logs Collection ====================
    // Only admins can read/write admin logs
    match /admin_logs/{logId} {
      allow read, write: if isAdmin();
    }

    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
